# 🔴 PRODUCTION ENVIRONMENT TEMPLATE
# DO NOT COMMIT THIS FILE - It contains production secrets!
# Copy this file to .env.production and fill in with real values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3002
NODE_ENV=production
HOST=0.0.0.0

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
# ⚠️  CHANGE THESE TO PRODUCTION VALUES
DB_HOST=your-production-db-host.com
DB_PORT=5432
DB_NAME=evaluasi_mi_production
DB_USER=evaluasi_user
DB_PASSWORD=your-strong-database-password-here

# ============================================
# JWT CONFIGURATION
# ============================================
# 🔑 IMPORTANT: Generate a strong secret key!
# Run this in Node.js console:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then paste the output below (minimum 32 characters)
JWT_SECRET=your-strong-random-secret-generated-above-minimum-32-chars
JWT_EXPIRES_IN=7d

# ============================================
# CORS CONFIGURATION
# ============================================
# List all allowed production domains separated by commas
# Example: https://yourdomain.com,https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
LOG_FILE=/var/log/evaluasi-mi/app.log

# ============================================
# DATABASE BACKUP
# ============================================
DB_BACKUP_ENABLED=true
DB_BACKUP_PATH=/var/backups/evaluasi-mi

# ============================================
# SECURITY
# ============================================
SECURE_COOKIES=true
SAME_SITE=Strict
